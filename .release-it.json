{
  "git": {
    "commitMessage": "chore(release): v${version} \n\n[skip ci]",
    "requireCleanWorkingDir": false
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  },
  "hooks": {
    "after:bump": "pnpm --filter animated-icons-vue exec npm version ${version} --no-git-tag-version",
    "after:release": "pnpm --filter animated-icons-vue publish --access public"
  }
}
